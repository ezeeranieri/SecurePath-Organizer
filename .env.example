# SecurePath Organizer Environment Configuration
# Copy this file to .env and configure as needed

# Optional: Discord/Slack webhook URL for security alerts when threats are quarantined
# WEBHOOK_URL=https://discord.com/api/webhooks/...

# Optional: Custom extension mappings (JSON format)
# EXTENSION_MAPPING={".custom": "CustomCategory"}

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
